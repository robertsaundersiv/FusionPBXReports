# Database Configuration
DB_NAME=phonereports
DB_USER=phonereports_user
DB_PASSWORD=your_secure_password_here
DB_HOST=db
DB_PORT=5432

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# FusionPBX API Configuration
FUSIONPBX_HOST=https://your-fusionpbx-server.com
FUSIONPBX_API_KEY=your_fusionpbx_api_key_here

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here_change_this_to_something_secure

# Environment Settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# Frontend API URL
VITE_API_URL=http://localhost:8000

