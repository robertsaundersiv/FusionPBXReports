# Database Configuration
DB_NAME=phonereports
DB_USER=phonereports_user
DB_PASSWORD=your_secure_password_here
DB_HOST=db
DB_PORT=5432

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# FusionPBX API Configuration
FUSIONPBX_HOST=https://your-fusionpbx-server.com
FUSIONPBX_API_KEY=your_fusionpbx_api_key_here

# Optional: FusionPBX web-session credentials for true wallboard parity
FUSIONPBX_WALLBOARD_USERNAME=
FUSIONPBX_WALLBOARD_PASSWORD=
FUSIONPBX_WALLBOARD_COOKIE=
FUSIONPBX_WALLBOARD_HOST=
FUSIONPBX_WALLBOARD_RESOURCE_PATH=/app/call_center_wallboard/resources/call_center_wallboard.php?queue_name=

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here_change_this_to_something_secure

# Login protection
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_LOGIN_RATE_LIMIT_MAX_ATTEMPTS=120
AUTH_LOGIN_LOCKOUT_THRESHOLD=5
AUTH_LOGIN_LOCKOUT_SECONDS=300

# Environment Settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# Frontend API URL
VITE_API_URL=http://localhost:8000

# Optional: Additional secrets or configurations
# Add any other environment variables your app needs