# FusionPBX Configuration
FUSIONPBX_HOST=https://your-pbx.example.com
FUSIONPBX_API_KEY=replace_with_api_key
FUSIONPBX_VERIFY_SSL=true

# Database Configuration
DATABASE_URL=postgresql://username:password@db:5432/phonereports
DB_HOST=localhost
DB_PORT=5432
DB_USER=phonereports
DB_PASSWORD=replace_with_db_password
DB_NAME=phonereports

# Redis Configuration (used by Celery)
REDIS_URL=redis://redis:6379/0

# JWT Secret for authentication
JWT_SECRET=replace_with_long_random_secret

# Environment
ENVIRONMENT=development
LOG_LEVEL=INFO

# Frontend API URL
VITE_API_URL=http://localhost:8000

# Timezone
DEFAULT_TIMEZONE=America/Denver

# Admin User
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_admin_password
ADMIN_EMAIL=admin@example.com
